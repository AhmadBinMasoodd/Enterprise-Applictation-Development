<Window x:Class="WPFApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFApp1"
        mc:Ignorable="d"
        Title="Student Portal" Height="450" Width="800">
    <Grid ShowGridLines="true">
        <Grid.ColumnDefinitions>
            <ColumnDefinition>
                
            </ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*">
                               
            </RowDefinition>
            <RowDefinition Height="2*">
                
            </RowDefinition>

        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>

            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center" >
                <TextBlock Text="Enter Student Name" FontSize="22"  HorizontalAlignment="Stretch" Margin="10"/>
                <TextBox Name="TbName" Text="" Margin="10" FontSize="20"/>
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" >
                <TextBlock Text="Enter Student Age" FontSize="22"  HorizontalAlignment="Stretch" Margin="10"/>
                <TextBox Name="TbAge" Text="" Margin="10" FontSize="20"/>
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                <Button Name="BtnAdd" Content="Add Student" Height="40"  Width="100" Margin="10" VerticalAlignment="Center" Click="add_Student" />
                <Button Name="BtnUpdate" Content="Update Student" Height="40" Width="100" Margin="10" VerticalAlignment="Center" Click="update_student" />

            </StackPanel>
            
        </Grid>

        <DataGrid Grid.Row="1" Grid.Column="0" Name="stdGrid" AutoGenerateColumns="False" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Width="2*" Header="Name" Binding="{Binding Sname}" >
                    
                </DataGridTextColumn>
                <DataGridTextColumn Width="2*" Header="Age" Binding="{Binding Sage}"></DataGridTextColumn>
                <DataGridTemplateColumn Width="Auto" Header="Edit">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Name="BtnEdit" Background="Blue" Click="edit_student">
                                <TextBlock Text="🖉" Foreground="White" ></TextBlock>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="Auto" Header="Delete">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Name="BtnDelete" Background="Red" Click="delete_student">
                                <TextBlock Text="🗑️" Foreground="White" ></TextBlock>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
