using Entity;
using data_service_layer;
namespace business_layer
{
    public class EmployeeService
    {
        private EmployeeRepository _repository;
        public EmployeeService()
        {
            _repository = new EmployeeRepository();
        }
        public void CreateEmployee(Employee employee)
        {

            if (employee.Age < 18)
            {
                employee.Age = 18; 
            }

            if (employee.Age < 30)
            {
                employee.Salary = 50000;  
            }
            else if (employee.Age < 35)
            {
                employee.Salary = 55000;   
            }
            else
            {
                employee.Salary = 70000;  
            }

            _repository.SaveEmployee(employee);
        }

        public void GetEmployees()
        {
            List<Employee> employees = _repository.GetAllEmployees();

            if (employees.Count == 0)
            {
                Console.WriteLine("No employees found");
                return;
            }

            Console.WriteLine("Employee List:");
            foreach (var emp in employees)
            {
                Console.WriteLine($"ID: {emp.Id}, Name: {emp.FirstName} {emp.LastName}, Age: {emp.Age}, Salary: {emp.Salary}, Department: {emp.Department}");
            }
        }

        public Employee GetEmployeeById(int id)
        {
            return _repository.GetEmployeeById(id);
        }

        public void UpdateEmployee(Employee employee)
        {
            if (employee.Age < 18)
            {
                employee.Age = 18;
            }

            if (employee.Age < 30)
            {
                employee.Salary = 50000;
            }
            else if (employee.Age < 35)
            {
                employee.Salary = 55000;
            }
            else
            {
                employee.Salary = 70000;
            }

            _repository.UpdateEmployee(employee);
        }

        public void DeleteEmployee(int id)
        {
            _repository.DeleteEmployee(id);
        }
    }
}
